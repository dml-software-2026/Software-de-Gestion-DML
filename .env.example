# Flask Config
SECRET_KEY=change-this-secret-key-in-production
FLASK_ENV=development

# Código de desbloqueo de registros freezados
UNFREEZE_CODE=change-this-unfreeze-code

# Contraseñas de usuarios por defecto (seed inicial)
PASSWORD_ADMIN=change-this
PASSWORD_RAYPAC=change-this
PASSWORD_TECNICO=change-this
PASSWORD_REPUESTOS=change-this

# Mail Config
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@dml.local

# Email de alertas de stock
MAIL_ALERT_RECIPIENT=repuestos@dml.local

# Database
DATABASE=dml.db
